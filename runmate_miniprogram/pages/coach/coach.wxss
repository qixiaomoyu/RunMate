/* pages/coach/coach.wxss */
.page { display: flex; flex-direction: column; height: 100vh; background: #f7faf8; }
.chat-area { flex: 1; padding: 20rpx; overflow-y: auto; }
.msg-row { display: flex; margin-bottom: 24rpx; align-items: flex-start; gap: 16rpx; }
.ai-row { flex-direction: row; }
.user-row { flex-direction: row-reverse; }
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #E1F5EE; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.bubble { max-width: 75%; padding: 20rpx 24rpx; border-radius: 24rpx; }
.ai-bubble { background: #fff; border-radius: 8rpx 24rpx 24rpx 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.user-bubble { background: #1D9E75; border-radius: 24rpx 8rpx 24rpx 24rpx; }
.ai-label { font-size: 20rpx; color: #1D9E75; font-weight: 600; display: block; margin-bottom: 6rpx; }
.bubble-text { font-size: 28rpx; line-height: 1.6; color: #1a1a1a; }
.user-bubble .bubble-text { color: #fff; }
.loading-bubble { color: #888; font-size: 26rpx; }
.dot-ani { animation: blink 1s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.chips-row { display: flex; padding: 12rpx 20rpx; gap: 12rpx; white-space: nowrap; background: #fff; border-top: 1rpx solid #f0f0f0; }
.chip { display: inline-block; padding: 10rpx 24rpx; border-radius: 40rpx; border: 1rpx solid #1D9E75; color: #1D9E75; font-size: 24rpx; white-space: nowrap; flex-shrink: 0; }

.input-bar { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx; background: #fff; border-top: 1rpx solid #f0f0f0; }
.chat-input { flex: 1; background: #f5f5f3; border-radius: 40rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.send-btn { background: #1D9E75; color: #fff; border-radius: 40rpx; padding: 16rpx 32rpx; font-size: 28rpx; font-weight: 600; flex-shrink: 0; }
.send-btn.disabled { background: #ccc; }
