/* pages/history/history.wxss */
.page { padding-bottom: 60rpx; }
.streak-card { margin: 24rpx; background: linear-gradient(135deg, #1D9E75, #085041); border-radius: 20rpx; padding: 32rpx; display: flex; justify-content: space-between; align-items: center; }
.streak-num { font-size: 80rpx; font-weight: 700; color: #fff; display: block; line-height: 1; }
.streak-label { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; display: block; }
.streak-month { font-size: 26rpx; color: #fff; font-weight: 600; display: block; text-align: right; }
.streak-cal { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; display: block; text-align: right; }

.record-item { display: flex; align-items: center; gap: 20rpx; }
.record-icon { width: 72rpx; height: 72rpx; border-radius: 50%; background: #E1F5EE; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.record-info { flex: 1; }
.record-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.record-sub { font-size: 22rpx; color: #888; margin-top: 4rpx; display: block; }
.record-dist { text-align: right; }
.dist-num { font-size: 40rpx; font-weight: 700; color: #1D9E75; display: block; }
.dist-unit { font-size: 20rpx; color: #888; display: block; }
