/* pages/index/index.wxss */
.page { padding-bottom: 40rpx; }

.header { background: linear-gradient(135deg, #1D9E75, #085041); padding: 40rpx 30rpx 36rpx; display: flex; justify-content: space-between; align-items: flex-start; }
.header-title { font-size: 44rpx; font-weight: 700; color: #fff; display: block; }
.header-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; display: block; }
.header-date { font-size: 24rpx; color: rgba(255,255,255,0.75); }

.stats-row { display: flex; gap: 16rpx; padding: 24rpx 24rpx 0; }
.stat-card { flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx 16rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.stat-num { font-size: 40rpx; font-weight: 700; color: #1D9E75; display: block; }
.stat-label { font-size: 20rpx; color: #999; margin-top: 6rpx; display: block; }

.task-card { cursor: pointer; }
.task-row { display: flex; align-items: center; gap: 20rpx; }
.task-icon { width: 88rpx; height: 88rpx; background: #E1F5EE; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; }
.task-info { flex: 1; }
.task-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; }
.task-sub { font-size: 24rpx; color: #888; margin-top: 6rpx; display: block; }
.badge-row { margin-top: 10rpx; }
.task-arrow { font-size: 44rpx; color: #ccc; }

.progress-header { display: flex; justify-content: space-between; margin-bottom: 14rpx; }
.progress-text { font-size: 24rpx; color: #666; }
.progress-pct { font-size: 24rpx; color: #1D9E75; font-weight: 600; }
.progress-hint { font-size: 22rpx; color: #999; margin-top: 12rpx; display: block; }
