<!--pages/plan/plan.wxml-->

<!-- ========== 加载中遮罩 ========== -->
<view class="loading-overlay" wx:if="{{isLoading}}">
  <view class="loading-card">
    <!-- 跑步动画 -->
    <view class="running-animation">
      <text class="runner-emoji">🏃‍♂️</text>
      <view class="running-track">
        <view class="track-progress" style="width: {{loadingProgress}}%"></view>
      </view>
      <text class="finish-flag">🏁</text>
    </view>

    <!-- 进度 -->
    <text class="loading-percent">{{loadingProgress}}%</text>
    <text class="loading-stage">{{loadingStage}}</text>

    <!-- 跑步小知识 -->
    <view class="tip-card">
      <text class="tip-label">💡 跑步小知识</text>
      <text class="tip-content">{{loadingTip}}</text>
    </view>
  </view>
</view>

<!-- ========== 未生成计划：选项页 ========== -->
<view class="container" wx:if="{{!hasPlan && !isLoading}}">
  <view class="header-text">生成个性化计划</view>

  <view class="option-card">
    <picker bindchange="onGoalChange" value="{{goalIndex}}" range="{{goalOptions}}">
      <view class="option-row">
        <text class="option-icon">🎯</text>
        <text class="option-label">跑步目标</text>
        <text class="option-value">{{goalOptions[goalIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onLevelChange" value="{{levelIndex}}" range="{{levelOptions}}">
      <view class="option-row">
        <text class="option-icon">🏃‍♂️</text>
        <text class="option-label">当前水平</text>
        <text class="option-value">{{levelOptions[levelIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onDaysChange" value="{{daysIndex}}" range="{{daysOptions}}">
      <view class="option-row">
        <text class="option-icon">📅</text>
        <text class="option-label">每周训练天数</text>
        <text class="option-value">{{daysOptions[daysIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onGenderChange" value="{{genderIndex}}" range="{{genderOptions}}">
      <view class="option-row">
        <text class="option-icon">👤</text>
        <text class="option-label">性别</text>
        <text class="option-value">{{genderOptions[genderIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onHeightChange" value="{{heightIndex}}" range="{{heightOptions}}">
      <view class="option-row">
        <text class="option-icon">📏</text>
        <text class="option-label">身高</text>
        <text class="option-value">{{heightOptions[heightIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onWeightChange" value="{{weightIndex}}" range="{{weightOptions}}">
      <view class="option-row">
        <text class="option-icon">⚖️</text>
        <text class="option-label">体重</text>
        <text class="option-value">{{weightOptions[weightIndex]}} ›</text>
      </view>
    </picker>

    <picker bindchange="onHabitChange" value="{{habitIndex}}" range="{{habitOptions}}">
      <view class="option-row">
        <text class="option-icon">💪</text>
        <text class="option-label">运动习惯</text>
        <text class="option-value">{{habitOptions[habitIndex]}} ›</text>
      </view>
    </picker>
  </view>

  <view class="generate-btn" bindtap="generatePlan">
    <text>✨ 生成我的专属计划</text>
  </view>
</view>

<!-- ========== 已生成计划：展示页 ========== -->
<view class="container" wx:if="{{hasPlan}}">
  
  <!-- 计划概览 -->
  <view class="plan-header">
    <text class="plan-title">🎯 你的专属训练计划</text>
    <text class="plan-summary">{{planSummary}}</text>
  </view>

  <!-- 周数切换 -->
  <view class="week-nav">
    <view class="nav-btn {{currentWeek <= 1 ? 'disabled' : ''}}" bindtap="prevWeek">
      <text>‹ 上一周</text>
    </view>
    <view class="week-indicator">
      <text class="week-current">第 {{currentWeek}} 周</text>
      <text class="week-total">/ 共 {{totalWeeks}} 周</text>
    </view>
    <view class="nav-btn {{currentWeek >= totalWeeks ? 'disabled' : ''}}" bindtap="nextWeek">
      <text>下一周 ›</text>
    </view>
  </view>

  <!-- 本周主题 -->
  <view class="week-theme" wx:if="{{weekData.theme}}">
    <text class="theme-text">📋 {{weekData.theme}}</text>
  </view>

  <!-- 加载更多周时的loading -->
  <view class="loading-more" wx:if="{{isLoadingMore}}">
    <text class="loading-more-text">AI教练正在编排第{{currentWeek}}周计划...</text>
  </view>

  <!-- 每日训练卡片 -->
  <view class="day-list" wx:if="{{!isLoadingMore && weekData.days}}">
    <view class="day-card {{item.type == '休息' ? 'rest' : item.type == '长跑' ? 'long-run' : item.type == '间歇跑' ? 'interval' : 'easy-run'}}" 
          wx:for="{{weekData.days}}" wx:key="day">
      <view class="day-header">
        <text class="day-name">{{item.day}}</text>
        <text class="day-type">{{item.type}}</text>
      </view>
      <view class="day-detail" wx:if="{{item.km > 0}}">
        <text class="day-km">{{item.km}}km</text>
        <text class="day-pace">配速 {{item.pace}}</text>
      </view>
      <text class="day-tip">{{item.tip}}</text>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions">
    <view class="regenerate-btn" bindtap="regenerate">
      <text>🔄 重新生成计划</text>
    </view>
  </view>

</view>
