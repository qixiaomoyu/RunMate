<!-- pages/run/run.wxml — 跑步页 -->
<view class="page">
  <view class="run-header">
    <text class="run-title">今日任务：轻松慢跑 5km</text>
    <text class="run-sub">目标配速 6'00"-6'30"</text>
  </view>

  <!-- 主数据圆圈 -->
  <view class="circle-wrap">
    <view class="run-circle {{running ? 'running' : ''}}">
      <text class="dist-num">{{distance}}</text>
      <text class="dist-unit">公里</text>
    </view>
  </view>

  <!-- 三项数据 -->
  <view class="metrics-row">
    <view class="metric">
      <text class="metric-val">{{timeStr}}</text>
      <text class="metric-key">用时</text>
    </view>
    <view class="metric">
      <text class="metric-val">{{pace}}</text>
      <text class="metric-key">配速/km</text>
    </view>
    <view class="metric">
      <text class="metric-val">{{calories}}</text>
      <text class="metric-key">千卡</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="card" style="margin-top:24rpx">
    <view class="progress-header">
      <text class="progress-text">目标 5km 进度</text>
      <text class="progress-pct">{{progressPct}}%</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width:{{progressPct}}%"></view>
    </view>
  </view>

  <!-- AI激励消息 -->
  <view class="encourage-box" wx:if="{{encourageMsg}}">
    <text class="encourage-text">💬 {{encourageMsg}}</text>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <button class="btn-run {{running ? 'btn-pause' : 'btn-start'}}" bindtap="toggleRun">
      {{running ? '暂停' : (seconds > 0 ? '继续' : '开始跑步')}}
    </button>
    <button class="btn-end" bindtap="endRun" wx:if="{{seconds > 0}}">结束</button>
  </view>
</view>
